<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/cardbg"
    android:gravity="center"
    android:orientation="vertical"
    tools:context=".Step21.Patient.CPatientHome.AFindDoctor.ADoctorDetailsAndBookAppointments.DoctorDetailsActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/toolbar_background"
        android:elevation="8dp"
        android:layout_gravity="top"
        app:titleTextColor="@color/purple"
        android:paddingTop="15dp"
        app:titleTextAppearance="@style/ToolbarTitleText"
        />




    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="600dp"
        android:layout_marginTop="3dp"
        android:layout_gravity="fill"
        app:cardBackgroundColor="#E1EDF6"
        app:cardCornerRadius="15dp"
        app:cardElevation="20dp"
        app:cardMaxElevation="16dp"
        app:cardUseCompatPadding="true">
        <ListView
            android:id="@+id/listViewDD"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:listSelector="@color/white"
            android:background="@color/white"
            />
    </androidx.cardview.widget.CardView>



        <TextView
            android:id="@+id/textViewDD"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="2dp"
            android:adjustViewBounds="true"
            android:padding="8dp"
            android:text="Titiles"
            android:textColor="@color/white"
            android:textSize="20dp"
            android:textStyle="bold" />


